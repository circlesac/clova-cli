{
  "name": "clova",
  "type": "module",
  "description": "CLOVA Note CLI — transcripts, summaries, speakers, and audio from the terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/circlesac/clova-cli"
  },
  "module": "src/index.ts",
  "bin": {
    "clova": "bin/clova"
  },
  "dependencies": {
    "citty": "^0.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "files": [
    "bin",
    "skills"
  ],
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "bun build --compile --outfile=dist/clova src/index.ts",
    "dev": "bun run src/index.ts",
    "test": "vitest run",
    "lint": "npx @circlesac/lint --all",
    "type-check": "npx tsc --noEmit",
    "pre-merge": "bun run lint && bun run type-check && bun run test && bun run build",
    "postinstall": "node bin/install.js"
  }
}
